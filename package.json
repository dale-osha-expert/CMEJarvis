    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "npx ts-node --project prisma/tsconfig.seed.json prisma/seed.ts",
    "db:studio": "prisma studio",
    "briefing:generate": "curl -s -X POST \"http://localhost:3000/api/cron/daily-briefing?force=true\" -H \"X-Cron-Secret: ${CRON_SECRET:-dev-secret}\" | node -e \"process.stdin.resume(); let d=''; process.stdin.on('data',c=>d+=c); process.stdin.on('end',()=>console.log(JSON.stringify(JSON.parse(d),null,2)))\""
  },
