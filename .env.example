# ─── Database ────────────────────────────────────────────────────────────────
# SQLite for local dev. Swap to postgresql://... for production.
DATABASE_URL="file:./dev.db"

# ─── Anthropic ───────────────────────────────────────────────────────────────
# Required: your Anthropic API key. Get one at console.anthropic.com
ANTHROPIC_API_KEY="sk-ant-..."
# Model to use. Update here when Anthropic retires a model version.
ANTHROPIC_MODEL="claude-sonnet-4-6"

# ─── Auth ────────────────────────────────────────────────────────────────────
# Authentication is handled at the network layer (reverse proxy / SSO / VPN).
# The app itself is UNAUTHENTICATED — see proxy.ts for the full warning.
# No JARVIS_USERNAME / JARVIS_PASSWORD vars; login has been removed entirely.

# ─── Feature Flags ───────────────────────────────────────────────────────────
# USE_STUBS=true  → all adapters return stub/fake data (default for dev)
# USE_STUBS=false → use real adapter implementations
USE_STUBS="true"

# ─── Spoken Briefing / TTS ───────────────────────────────────────────────────
# TTS_PROVIDER: stub | openai | elevenlabs  (default: stub — no API key needed)
TTS_PROVIDER="stub"

# Required only for TTS_PROVIDER=openai:
# OPENAI_API_KEY="sk-..."
# OPENAI_TTS_MODEL="gpt-4o-mini-tts"    # or tts-1, tts-1-hd
# TTS_VOICE="onyx"                       # alloy | ash | coral | echo | fable | onyx | nova | sage | shimmer

# Required only for TTS_PROVIDER=elevenlabs (slot not yet implemented):
# ELEVENLABS_API_KEY=""
# TTS_VOICE="your-voice-id"              # voice ID from ElevenLabs dashboard

# ─── Scheduling ──────────────────────────────────────────────────────────────
# Secret for the /api/cron/daily-briefing endpoint (used by OS cron jobs / curl)
# Generate with: openssl rand -hex 32
CRON_SECRET="dev-secret-replace-in-production"
# Timezone for the in-process node-cron scheduler (1:00 AM daily)
BRIEFING_TIMEZONE="America/New_York"

# ─── Real Integrations (leave empty until implemented) ───────────────────────

# Shopify (Analytics adapter — orders, revenue, refunds)
# SHOPIFY_SHOP_DOMAIN="certifyme.myshopify.com"
# SHOPIFY_ACCESS_TOKEN=""

# Google Analytics 4 (Analytics adapter — traffic, sessions)
# GA4_PROPERTY_ID=""
# GA4_SERVICE_ACCOUNT_JSON=""

# Google Ads API (lib/adapters/ads/google.real.ts)
# GOOGLE_ADS_DEVELOPER_TOKEN=""
# GOOGLE_ADS_CLIENT_ID=""
# GOOGLE_ADS_CLIENT_SECRET=""
# GOOGLE_ADS_REFRESH_TOKEN=""
# GOOGLE_ADS_CUSTOMER_ID=""              # 10-digit account ID, no dashes

# Meta Ads API (lib/adapters/ads/meta.real.ts)
# META_APP_ID=""
# META_APP_SECRET=""
# META_ACCESS_TOKEN=""                   # long-lived system-user token
# META_AD_ACCOUNT_ID="act_..."

# Gmail API (Support adapter)
# GMAIL_CLIENT_ID=""
# GMAIL_CLIENT_SECRET=""
# GMAIL_REFRESH_TOKEN=""
# GMAIL_USER_EMAIL="support@certifyme.net"

# Brave Search API (Research adapter)
# BRAVE_SEARCH_API_KEY=""

# ─── RBE (Real Backend / Storefront) ─────────────────────────────────────────
# Used by the Ads Summary tab for "RBE Actual Rev" and "RBE Total Sales".
# See lib/adapters/rbe/rbe.placeholder.ts for the integration slot.
# RBE_API_URL=""                         # base URL of the RBE storefront API
# RBE_API_KEY=""                         # API key or bearer token
